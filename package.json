{
  "name": "@shaferllc/keel",
  "version": "0.83.4",
  "type": "module",
  "description": "The house framework for Node.js — a service container, providers, routing, JSX views, and a code-generating console.",
  "license": "MIT",
  "author": "Tom Shafer",
  "homepage": "https://github.com/shaferllc/keel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaferllc/keel.git"
  },
  "keywords": [
    "framework",
    "typescript",
    "nodejs",
    "hono",
    "service-container",
    "web-framework",
    "edge",
    "cloudflare-workers",
    "mcp",
    "model-context-protocol",
    "ai",
    "llms-txt"
  ],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./db/d1": {
      "types": "./dist/db/d1.d.ts",
      "import": "./dist/db/d1.js"
    },
    "./db/d1-http": {
      "types": "./dist/db/d1-http.d.ts",
      "import": "./dist/db/d1-http.js"
    },
    "./db/pg": {
      "types": "./dist/db/pg.d.ts",
      "import": "./dist/db/pg.js"
    },
    "./db/libsql": {
      "types": "./dist/db/libsql.d.ts",
      "import": "./dist/db/libsql.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./watch": {
      "types": "./dist/watch/index.d.ts",
      "import": "./dist/watch/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "import": "./dist/openapi/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./accounts": {
      "types": "./dist/accounts/index.d.ts",
      "import": "./dist/accounts/index.js"
    },
    "./teams": {
      "types": "./dist/teams/index.d.ts",
      "import": "./dist/teams/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js"
    },
    "./gates": {
      "types": "./dist/gates/index.d.ts",
      "import": "./dist/gates/index.js"
    },
    "./hosting": {
      "types": "./dist/hosting/index.d.ts",
      "import": "./dist/hosting/index.js"
    },
    "./cli": {
      "types": "./dist/core/cli/index.d.ts",
      "import": "./dist/core/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "keel-mcp": "./bin/keel-mcp.mjs"
  },
  "files": [
    "dist",
    "bin/keel-mcp.mjs",
    "docs",
    "AGENTS.md",
    "llms.txt",
    "llms-full.txt",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "mcp": "tsx bin/keel-mcp.ts",
    "typecheck": "tsc --noEmit && npm run typecheck:tests",
    "typecheck:docs": "npm run build && tsc -p tsconfig.docs.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-exclude='tests/**' tests/*.test.ts",
    "build:ai": "tsx scripts/build-ai.ts",
    "build:watch-ui": "vite build --config src/watch/ui/vite.config.ts",
    "build:watch-copy": "mkdir -p dist/watch/ui && cp -R src/watch/ui/dist dist/watch/ui/dist && cp src/watch/watch.config.stub dist/watch/ && cp src/openapi/openapi.config.stub dist/openapi/ && cp src/api/api.config.stub dist/api/ && cp src/billing/billing.config.stub dist/billing/ && cp src/accounts/accounts.config.stub dist/accounts/ && cp src/teams/teams.config.stub dist/teams/",
    "build": "npm run build:ai && npm run build:watch-ui && rm -rf dist && tsc -p tsconfig.build.json && npm run build:watch-copy",
    "prepare": "npm run build",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "verify:release": "bash scripts/verify-release.sh",
    "version": "npm run build:ai && git add docs/ai-manifest.json llms.txt llms-full.txt"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7",
    "@hono/node-server": "^1.13.7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.17.4",
    "@types/node": "^26.1.1",
    "preact": "^10.29.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3"
  }
}
