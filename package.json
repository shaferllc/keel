{
  "name": "@shaferllc/keel",
  "version": "0.70.0",
  "type": "module",
  "description": "The house framework for Node.js — a service container, providers, routing, JSX views, and a code-generating console.",
  "license": "MIT",
  "author": "Tom Shafer",
  "homepage": "https://github.com/shaferllc/keel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaferllc/keel.git"
  },
  "keywords": [
    "framework",
    "typescript",
    "nodejs",
    "hono",
    "service-container",
    "web-framework",
    "edge",
    "cloudflare-workers",
    "mcp",
    "model-context-protocol",
    "ai",
    "llms-txt"
  ],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./db/d1": {
      "types": "./dist/db/d1.d.ts",
      "import": "./dist/db/d1.js"
    },
    "./db/pg": {
      "types": "./dist/db/pg.d.ts",
      "import": "./dist/db/pg.js"
    },
    "./db/libsql": {
      "types": "./dist/db/libsql.d.ts",
      "import": "./dist/db/libsql.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "keel-mcp": "./bin/keel-mcp.mjs"
  },
  "files": [
    "dist",
    "bin/keel-mcp.mjs",
    "docs",
    "AGENTS.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "keel": "tsx bin/keel.ts",
    "serve": "tsx bin/keel.ts serve",
    "dev": "tsx watch bin/keel.ts serve",
    "mcp": "tsx bin/keel-mcp.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:docs": "npm run build && tsc -p tsconfig.docs.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-exclude='tests/**' tests/*.test.ts",
    "build:ai": "tsx scripts/build-ai.ts",
    "build": "npm run build:ai && rm -rf dist && tsc -p tsconfig.build.json",
    "dev:client": "vite",
    "build:client": "vite build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/node": "^26.1.1",
    "commander": "^12.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3"
  }
}
