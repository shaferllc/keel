{
  "name": "@shaferllc/keel",
  "version": "0.4.0",
  "type": "module",
  "description": "The house framework for Node.js — a service container, providers, routing, JSX views, and a code-generating console.",
  "license": "MIT",
  "author": "Tom Shafer",
  "homepage": "https://github.com/shaferllc/keel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaferllc/keel.git"
  },
  "keywords": [
    "framework",
    "typescript",
    "nodejs",
    "hono",
    "service-container",
    "web-framework",
    "edge",
    "cloudflare-workers"
  ],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "keel": "tsx bin/keel.ts",
    "serve": "tsx bin/keel.ts serve",
    "dev": "tsx watch bin/keel.ts serve",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/node": "^26.1.1",
    "commander": "^12.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
