node_modules/
dist/
*.log
.DS_Store

# Vite build artifacts + dev-server marker
public/hot
public/assets/

# Local environment — copy .env.example to .env
.env
# ...but the boot test's fixture env IS part of the suite. The blanket `.env` rule
# above was hiding it, so `tests/boot.test.ts` only passed on a machine that happened
# to have the untracked file — and failed in CI, on a fresh checkout, immediately.
!tests/fixtures/.env
!.env.example

# Example-app demo database
database/*.sqlite

.cursor/hooks/state/

# Agent worktrees. These are real git worktrees, so git records one as a gitlink
# (mode 160000) if it is ever added — and a gitlink with no .gitmodules entry makes
# actions/checkout fail its cleanup with "No url found for submodule path".
.claude/worktrees/
