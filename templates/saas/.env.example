APP_NAME="Keel SaaS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000

# Signs tokens and encrypted payloads. Generate one: keel key:generate
APP_KEY=local-dev-key-change-me-in-production

# A file is enough to start; point this at Postgres when you outgrow it.
DB_CONNECTION=sqlite
DB_URL=file:./database.sqlite

# The from address on every email the app sends — verification, password reset, and
# team invitations. Invitations throw without one, so this is not optional.
MAIL_FROM=noreply@localhost

# Billing — omit STRIPE_SECRET_KEY to use FakeGateway locally.
BILLING_GATEWAY=
BILLING_CURRENCY=usd
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=price_pro

# Social sign-in. Leave a client id blank and that provider is simply not offered —
# no button on the login page, and its routes 403. Fill both values to turn one on.
#
#   GitHub  — https://github.com/settings/developers  (callback: APP_URL/auth/github/callback)
#   Google  — https://console.cloud.google.com/apis/credentials
#             (redirect URI: APP_URL/auth/google/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API docs. Swagger UI at /docs, spec at /docs/openapi.json — open in development,
# shut in production unless OPENAPI_PUBLIC=true.
OPENAPI_ENABLED=true
OPENAPI_PUBLIC=false
