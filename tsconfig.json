{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@keel/core": ["src/core/index.ts"],
      "@keel/watch": ["src/watch/index.ts"],
      "@keel/*": ["src/core/*"]
    },
    "noEmit": true
  },
  "include": ["src", "app", "bootstrap", "config", "routes", "bin"],
  "exclude": ["node_modules", "dist", "src/watch/ui"]
}
